# StoreSense Backend Environment Configuration
# =============================================
# Copy this file to .env and update with your values

# MongoDB Connection
# For local development: mongodb://localhost:27017/storesense
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/storesense
MONGODB_URI=mongodb://localhost:27017/storesense

# Server Configuration
PORT=3001
NODE_ENV=development

# Optional: Store identification (for multi-store deployments)
# STORE_ID=store-001
